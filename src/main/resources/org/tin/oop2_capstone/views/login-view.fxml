<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" styleClass="light" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.tin.oop2_capstone.controllers.LoginController">
   <BorderPane prefHeight="400.0" prefWidth="600.0" styleClass="light" AnchorPane.bottomAnchor="0.0"
               AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <left>
         <VBox alignment="CENTER" prefHeight="400.0" prefWidth="272.0" spacing="10.0" BorderPane.alignment="CENTER">
            <ImageView fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
               <Image url="@../assets/image/logo.png"/>
            </ImageView>
            <Label text="+inHealth"/>
            <Label text="Adding to your health in meaningfulll ways"/>
         </VBox>
      </left>
      <center>
         <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0" BorderPane.alignment="CENTER">
            <BorderPane.margin>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </BorderPane.margin>
            <padding>
               <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
            </padding>
            <Label prefHeight="17.0" prefWidth="278.0" text="Username">
               <VBox.margin>
                  <Insets/>
               </VBox.margin>
            </Label>
            <TextField/>
            <Label prefHeight="17.0" prefWidth="271.0" text="Password"/>
            <TextField/>
            <Button fx:id="buttonLogin" minWidth="268.0" mnemonicParsing="false" onAction="#onLoginButtonClicked" text="Login">
               <VBox.margin>
                  <Insets top="5.0"/>
               </VBox.margin>
            </Button>
            <Label text="Don't have an account? Sign Up"/>
         </VBox>
      </center>
      <padding>
         <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
      </padding>
   </BorderPane>
</AnchorPane>
