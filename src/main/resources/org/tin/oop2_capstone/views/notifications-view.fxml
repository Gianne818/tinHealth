<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.tin.oop2_capstone.screens.notification_tab.NotificationTabController">

    <content>
        <VBox spacing="16.0" maxWidth="1.7976931348623157E308">
            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/></padding>

            <!-- Header row -->
            <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="10.0">
                <Label fx:id="titleLabel" text="Notifications" styleClass="boldText">
                    <font><Font size="26.0"/></font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="markAllReadButton" mnemonicParsing="false"
                        text="Mark all as read"
                        styleClass="notif-mark-all-button"
                        onAction="#onMarkAllRead"/>
            </HBox>

            <!-- Subtitle -->
            <Label fx:id="subtitleLabel" text="You have 2 unread notifications" styleClass="lightText">
                <font><Font size="13.0"/></font>
                <VBox.margin><Insets top="-12.0"/></VBox.margin>
            </Label>

            <!-- Notification cards injected here by controller -->
            <VBox fx:id="notificationsContainer" spacing="10.0" maxWidth="1.7976931348623157E308"/>

        </VBox>
    </content>
</ScrollPane>