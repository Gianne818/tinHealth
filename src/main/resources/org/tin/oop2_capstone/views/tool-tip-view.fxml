<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="toolTipVbox" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.tin.oop2_capstone.controllers.ToolTipController">
    <children>
        <Label fx:id="dayLabel" styleClass="boldText" text="dayLabel" style="-fx-font-weight: bold; -fx-font-size: 16.0" >
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>
        <GridPane fx:id="calInGridPane">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Calories In:" style="-fx-font-weight: bold" />
                <Label fx:id="calInLabel" text="calInLabel" GridPane.columnIndex="1" style="-fx-font-weight: bold" />
            </children>
        </GridPane>
        <GridPane fx:id="calOutGridPane">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Calories Burned:" style="-fx-font-weight: bold" />
                <Label fx:id="calOutLabel" text="calOutLabel" GridPane.columnIndex="1" style="-fx-font-weight: bold" />
            </children>
        </GridPane>
    </children>
    <padding>
        <Insets bottom="20.0" left="10.0" right="10.0" top="20.0" />
    </padding>
</VBox>

